{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-memory-handoff.v1",
  "title": "Agent Memory Handoff Bundle v1",
  "description": "Portable memory/policy/session handoff payload for model-agnostic continuity.",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "namespace",
    "memories",
    "sessions",
    "prompt_md",
    "stats"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agent-memory-handoff.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": [
        "string",
        "null"
      ]
    },
    "k": {
      "type": "integer",
      "minimum": 1
    },
    "policy": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "version_id": {
              "type": "string"
            },
            "content_md": {
              "type": "string"
            },
            "created_at": {
              "type": "string"
            },
            "content_sha256": {
              "type": "string"
            },
            "signing_method": {
              "type": "string"
            },
            "source_proposal_id": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "content_md"
          ],
          "additionalProperties": true
        }
      ]
    },
    "memories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "session_id",
          "content"
        ],
        "properties": {
          "memory_id": {
            "type": "integer",
            "minimum": 1
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "type": "object"
          },
          "score": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "session_id",
          "events"
        ],
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "event_count": {
            "type": "integer",
            "minimum": 0
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "role",
                "content",
                "created_at"
              ],
              "properties": {
                "id": {
                  "type": "integer",
                  "minimum": 1
                },
                "role": {
                  "type": "string",
                  "minLength": 1
                },
                "content": {
                  "type": "string",
                  "minLength": 1
                },
                "created_at": {
                  "type": "string",
                  "minLength": 1
                },
                "metadata": {
                  "type": "object"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "prompt_md": {
      "type": "string"
    },
    "stats": {
      "type": "object",
      "required": [
        "memory_count",
        "session_count",
        "event_count"
      ],
      "properties": {
        "memory_count": {
          "type": "integer",
          "minimum": 0
        },
        "session_count": {
          "type": "integer",
          "minimum": 0
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
